# ===== LLM =====
# 留空则使用内置 mock grader（P1.0 起步）；配置后自动切换到真实 LLM
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1500
LLM_TIMEOUT=30

# ===== App =====
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000

# ===== Database =====
DATABASE_URL=sqlite:///./data/code_grader.db

# ===== Cache =====
GRADE_CACHE_TTL=86400
GRADE_CACHE_MAXSIZE=1024
