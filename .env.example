# ===== LLM =====
# 留空则使用内置 mock grader（P1.0 起步）；配置后自动切换到真实 LLM
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1500
LLM_TIMEOUT=30

# ===== App =====
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000

# ===== Database =====
DATABASE_URL=sqlite:///./data/code_grader.db

# ===== Cache =====
GRADE_CACHE_TTL=86400
GRADE_CACHE_MAXSIZE=1024

# ===== Sandbox (P2.x 硬化) =====
# 后端：subprocess (默认) | docker (P2.y 计划)
SANDBOX_BACKEND=subprocess
# 虚拟内存上限（MB；超限 OOM-killed）
SANDBOX_MEMORY_MB=256
# 进程数上限（防 fork bomb）
SANDBOX_MAX_PROCESSES=32
# CPU 时间上限（秒；0 = 自动 = wall_timeout + 1）
SANDBOX_CPU_TIME_SEC=0

# ===== Ingestion / OCR =====
# OCR 后端： mock | paddleocr | tesseract | vision_api
INGESTION_OCR_BACKEND=mock
# 人工抽检比例
INGESTION_REVIEW_RATIO=0.1

# ===== Vision API（仅当 INGESTION_OCR_BACKEND=vision_api 时使用）=====
VISION_API_KEY=
VISION_API_BASE=https://api.openai.com/v1
VISION_MODEL=gpt-4o
